#include "UpCounter.h"

typedef enum {
	STOP, RUN, CLEAR
} upcounter_state_t;

typedef enum {
	RELEASED = 0, PUSHED, NO_ACT

} button_state_t;

typedef enum {
	GPIO_Typedef_t *GPIOx;
	uint32_t GPIO_Pin;

	button_state_t prevState;
}hBtn_t;

hBtn_t hBtnRunStop, hBtnClear;

void Button_Init() {
GPIO_SetMode(GPIOA, GPIO_PIN_4 | GPIO_PIN_5 | GPIO_PIN_6 | GPIO_PIN_7,
INPUT);
hBtnRunStop.GPIOx = GPIOA;
hBtnRunStop.GPIO_Pin = GPIO_PIN_4;
hBtnRunStop.prevState = RELEASED;

hBtnRunClear.GPIOx = GPIOA;
hBtnRunClear.GPIO_Pin = GPIO_PIN_7;
hBtnRunClear.prevState = RELEASED;
}

button_state_t Button_GetState(hBtn_t) {
//static button_state_t prevState = RELEASED;
button_state_t curState = GPIO_ReadPin(hbtn->GPIOx, hbtn->GPIO_Pin);
if (prevState == RELEASED && curState == PUSHED) {
	delay_ms(5);
	prevState = PUSHED;
	return ACT_PUSHED;

} else if (prevState == PUSHED && curState == RELEASED) {
	delay_ms(5);
	prevState = RELEASED;
	return ACT_RELEASED;
}
return NO_ACT;
}



uint32_t counter = 0;

void UpCounter_Init() {
FND_Init();
Button_Init();
counter = 0;
}

void UpCounter_Excute() {
UpCounter_DispLoop();
static upcounter_state_t upCounterState = STOP;

switch (upCounterState) {
case STOP:
	UpCounter_Stop();
	if (Button_GetState() == PUSHED) {
		upCounterState = RUN;
	} else if (Button2_GetState() == PUSHED) {
		upCounterState = CLEAR;
	}
	break;
case RUN:
	UpCounter_Run();
	if (Button_GetState() == PUSHED) {
		upCounterState = STOP;
	}
	break;
case CLEAR:
	UpCounter_Clear();
	if (Button_GetState() == PUSHED) {
		upCounterState = RUN;
	}
	break;
default:
	UpCounter_Stop();
	break;
}
}
void UpCounter_DispLoop() {
FND_DispDigit();
}

void UpCounter_Run() {

static uint32_t prevTimeCounter = 0;

if (millis() - prevTimeCounter < 100 - 1) {
	return;
}
prevTimeCounter = millis();

FND_SetNum(counter++);

}

void UpCounter_Stop() {

FND_SetNum(counter);

}

void UpCounter_Clear() {

counter = 0;
FND_SetNum(counter);
}
