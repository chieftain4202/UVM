#include <stdint.h>
#include "xparameters.h"
#include "sleep.h"
#include "xil_printf.h"
#include "HAL/GPIO/GPIO.h"
#include "Driver/FND/fnd.h"
#include "common/common.h"

int main() {

	FND_Init();
	uint32_t counter = 0;
	uint32_t prevTimeCounter = 0;

	while (1) {

		if (millis() - prevTimeCounter >= 100){
			prevTimeCounter = millis();
			FND_SetNum(counter++);
		}

		FND_DispDigit();
		millis_inc();
		delay_ms(1);
	}
	return 0;
}
