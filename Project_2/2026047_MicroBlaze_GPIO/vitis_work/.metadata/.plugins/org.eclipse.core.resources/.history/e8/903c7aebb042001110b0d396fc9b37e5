#include <stdint.h>
#include "xparameters.h"
#include "sleep.h"
#include "xil_printf.h"
#include "HAL/GPIO/GPIO.h"
#include "Driver/FND/fnd.h"

uint32_t millis_tick = 0;

uint32_t millis() {
	return millis_tick;
}

void millis_inc() {
	millis_tick++;
}

void delay_ms(uint32_t msec) {
	usleep(msec * 1000);
}

void delay_us(uint32_t usec) {
	usleep(usec);
}

int main() {

	FND_Init();
//	uint32_t counter = 0;
	FND_SetNum(1234);
	uint32_t prevTimeDisp = 0;
	uint32_t prevTimeCounter = 0;

	while (1) {

		if (mills() - prevTimeDisp >= 1)
		FND_DispDigit();

		delay_ms(1);
		millis_inc();
	}
	return 0;
}
