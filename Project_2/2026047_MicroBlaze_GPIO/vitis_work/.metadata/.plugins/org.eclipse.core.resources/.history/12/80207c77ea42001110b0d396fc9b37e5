#include "Clock.h"



int clockdoton;
hBtn_t hBtnHour, hBtnSec;

uint32_t clock_t clockData;

void Clock_Init() {
	FND_Init();
}

void Clock_Run() {


	if (clockData.hour == 24) {
		clockData.hour = 0;
	} else if (clockData.min == 60) {
		clockData.min = 0;
		clockData.hour = clockData.hour + 1;
	} else if (clockData.sec == 60) {
		clockData.sec = 0;
		clockData.min = clockData.min + 1;
	}

	if (millis() - clockData.msec < 1000 - 1) {


		return;
	}


	clockData.msec = millis();
	clockData.sec = clockData.sec + 1;

}

void Clock_Excute() {
	if ((millis() / 500) % 2 == 0) {
			    FND_DotPoint(1);
			} else {
			    FND_DotPoint(0);
			}
	FND_DispDigit();
	FND_SetNum(clockData.min * 100 + clockData.sec);


}
