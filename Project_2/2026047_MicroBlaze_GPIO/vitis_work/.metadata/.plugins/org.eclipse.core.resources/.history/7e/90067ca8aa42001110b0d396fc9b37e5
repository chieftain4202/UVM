int main() {
	// GPIOA_CR = 0x0f;
	// GPIOB_CR = 0xff;
	GPIOA->CR = 0x0f;
	GPIOB->CR = 0xff;

	GPIO_SetMode(GPIOA, GPIO_PIN_0 | GPIO_PIN_1 | GPIO_PIN_2 | GPIO_PIN_3,
	OUTPUT);
	GPIO_SetMode(GPIOA, GPIO_PIN_4 | GPIO_PIN_5 | GPIO_PIN_6 | GPIO_PIN_7,
	INPUT);
	GPIO_SetMode(GPIOB, GPIO_PIN_0 | GPIO_PIN_1 | GPIO_PIN_2 | GPIO_PIN_3,
	OUTPUT);
	GPIO_SetMode(GPIOB, GPIO_PIN_4 | GPIO_PIN_5 | GPIO_PIN_6 | GPIO_PIN_7,
	OUTPUT);

	while (1) {

		GPIO_WritePort(GPIOB, 0x00);
		if (GPIO_ReadPin(GPIOA, GPIO_PIN_4)) {
			GPIO_WritePin(GPIOA, GPIO_PIN_0, RESET);
		} else if (GPIO_ReadPin(GPIOA, GPIO_PIN_5)) {
			GPIO_WritePin(GPIOA, GPIO_PIN_1, RESET);
		} else if (GPIO_ReadPin(GPIOA, GPIO_PIN_6)) {
			GPIO_WritePin(GPIOA, GPIO_PIN_2, RESET);
		} else if (GPIO_ReadPin(GPIOA, GPIO_PIN_7)) {
			GPIO_WritePin(GPIOA, GPIO_PIN_3, RESET);
		} else {
			GPIO_WritePin(GPIOA,
			GPIO_PIN_0 | GPIO_PIN_1 | GPIO_PIN_2 | GPIO_PIN_3, SET);
		}
	}

	return 0;
}
